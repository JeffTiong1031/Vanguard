new file mode 100644
index 0000000..ef1bac8
--- /dev/null
+++ b/code/extension/src/util/debounce.ts
@@ -0,0 +1,10 @@
+export function debounce<A extends unknown[]>(
+  fn: (...args: A) => void,
+  ms: number,
+): (...args: A) => void {
+  let timer: ReturnType<typeof setTimeout> | undefined;
+  return (...args: A) => {
+    clearTimeout(timer);
+    timer = setTimeout(() => fn(...args), ms);
+  };
+}
