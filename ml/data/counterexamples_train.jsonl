{"id": "bias-brk-065", "text": "尽快取消我们公司在星巴克绑定的企业员工餐饮预付卡余额。", "lang": "zh", "spans": [{"start": 9, "end": 12, "surface": "星巴克", "entity_type": "ORG", "label": "MASK"}], "provenance": "human_simulated", "split": "train", "source": "team_author", "tags": ["known_entity_private"]}
{"id": "bias-brk-066", "text": "记得去核实一下京东寄过来的那几张采购增值税发票的真伪。", "lang": "zh", "spans": [{"start": 7, "end": 9, "surface": "京东", "entity_type": "ORG", "label": "MASK"}], "provenance": "human_simulated", "split": "train", "source": "team_author", "tags": ["known_entity_private"]}
{"id": "bias-brk-067", "text": "Boss minta tolong settlekan payment pending untuk Google Cloud services tu.", "lang": "mixed", "spans": [{"start": 50, "end": 62, "surface": "Google Cloud", "entity_type": "ORG", "label": "MASK"}], "provenance": "human_simulated", "split": "train", "source": "team_author", "tags": ["known_entity_private"]}
{"id": "bias-brk-068", "text": "I dah hantar the legal warning letter to Samsung Electronics pasal contract breach tu.", "lang": "mixed", "spans": [{"start": 41, "end": 60, "surface": "Samsung Electronics", "entity_type": "ORG", "label": "MASK"}], "provenance": "human_simulated", "split": "train", "source": "team_author", "tags": ["known_entity_private"]}
{"id": "bias-brk-069", "text": "Kena double check our corporate outstanding balance with CIMB Bank before audit.", "lang": "mixed", "spans": [{"start": 57, "end": 66, "surface": "CIMB Bank", "entity_type": "ORG", "label": "MASK"}], "provenance": "human_simulated", "split": "train", "source": "team_author", "tags": ["known_entity_private"]}
{"id": "bias-brk-070", "text": "Tolong cancel the automatic renewal subscription from 阿里巴巴 immediately.", "lang": "mixed", "spans": [{"start": 54, "end": 58, "surface": "阿里巴巴", "entity_type": "ORG", "label": "MASK"}], "provenance": "human_simulated", "split": "train", "source": "team_author", "tags": ["known_entity_private"]}
{"id": "bias-brk-071", "text": "We still haven't received the compensation transfer from Grab Malaysia for the accident.", "lang": "mixed", "spans": [{"start": 57, "end": 70, "surface": "Grab Malaysia", "entity_type": "ORG", "label": "MASK"}], "provenance": "human_simulated", "split": "train", "source": "team_author", "tags": ["known_entity_private"]}
{"id": "bias-brk-072", "text": "Please forward the overdue invoice notice to the person in charge at 华为.", "lang": "mixed", "spans": [{"start": 69, "end": 71, "surface": "华为", "entity_type": "ORG", "label": "MASK"}], "provenance": "human_simulated", "split": "train", "source": "team_author", "tags": ["known_entity_private"]}
