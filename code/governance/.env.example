# Copy this file to .env.local and fill in real values.
# After `supabase start`, run `supabase status` to get local URL/keys, or use
# the values from your hosted Supabase project's dashboard for a deployed env.

# Public — safe to ship in the browser bundle. Next.js only inlines
# NEXT_PUBLIC_-prefixed vars into client-side code, which is why these two
# carry that prefix even though the source task brief named them without it:
# an unprefixed SUPABASE_ANON_KEY would read as undefined inside any code
# that actually runs in the browser (see lib/supabase/browser.ts).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Deliberately NOT prefixed with NEXT_PUBLIC_ — if it were,
# Next.js would inline it into the browser bundle. Bypasses Row Level
# Security. Only ever read this from server-only code (Route Handlers,
# Server Actions, Server Components) via lib/supabase/service.ts, which
# throws if this is unset — including when accidentally evaluated in a
# browser bundle, where it is always undefined regardless of this file.
SUPABASE_SERVICE_ROLE_KEY=
